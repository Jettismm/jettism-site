  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html,body{width:100%;height:100%;overflow:hidden;
      background:radial-gradient(ellipse at 50% 50%,#1700FF 10%,#0800C0 100%)}

    /* ── Shorts strips (hidden until crown clicked) ── */
    .strip{
      position:fixed;top:0;bottom:0;width:155px;overflow:hidden;z-index:5;
      opacity:0;pointer-events:none;
      transition:opacity 0.6s ease;
    }
    .strip.visible{opacity:1;pointer-events:auto}
    .strip.L{left:0}.strip.R{right:0}
    .strip::before,.strip::after{
      content:'';position:absolute;left:0;right:0;height:120px;z-index:2;pointer-events:none}
    .strip::before{top:0;background:linear-gradient(to bottom,#0800C0 0%,transparent 100%)}
    .strip::after{bottom:0;background:linear-gradient(to top,#0800C0 0%,transparent 100%)}
    @keyframes scrollup{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .si{display:flex;flex-direction:column;gap:8px;padding:4px;
         animation:scrollup 55s linear infinite}
    .si-off{animation-delay:-27.5s}
    .sc{display:block;position:relative;width:147px;height:261px;
         border-radius:10px;overflow:hidden;text-decoration:none;flex-shrink:0}
    .sc img{width:100%;height:100%;object-fit:cover;object-position:center top}
    .pi{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
         font-size:26px;color:rgba(255,255,255,.88);background:rgba(0,0,0,.22);
         opacity:0;transition:opacity .2s ease}
    .sc:hover .pi{opacity:1}
    @media(max-width:860px){.strip{display:none}}

    /* ── Crown ── */
    #crown{position:fixed;left:0;top:0;width:220px;height:auto;
           opacity:0;pointer-events:none;touch-action:none;
           filter:drop-shadow(0 7px 22px rgba(0,0,0,.65));
           transform-origin:50% 100%;will-change:left,top,transform;
           transition:opacity .6s ease;user-select:none;-webkit-user-drag:none}
    @keyframes idle-glow{
      0%,100%{filter:drop-shadow(0 7px 22px rgba(0,0,0,.65))}
      50%{filter:drop-shadow(0 7px 22px rgba(0,0,0,.65)) drop-shadow(0 0 32px rgba(255,232,0,.44))}
    }
    #crown.idle{cursor:pointer;animation:idle-glow 2.4s ease-in-out infinite}
    #crown.grab{cursor:grab}
    #crown.grabbing{cursor:grabbing}

    /* ── Content (hidden until crown clicked) ── */
    #content{position:fixed;left:0;right:0;
              display:flex;flex-direction:column;align-items:center;
              opacity:0;pointer-events:none;transition:opacity .55s ease}
    #content.visible{opacity:1;pointer-events:auto}
    @keyframes wiggle{0%,100%{transform:rotate(-2.5deg)}50%{transform:rotate(2.5deg)}}
    #coming-soon{font-family:'Montserrat','Arial Black',sans-serif;font-weight:800;
                  font-size:clamp(26px,5vw,52px);color:#000;
                  display:inline-block;letter-spacing:-.5px;white-space:nowrap}
    #coming-soon.wiggling{animation:wiggle .45s ease-in-out infinite}
    .watch-btn{display:inline-block;margin-top:42px;padding:13px 32px;
                background:#000;color:#fff;font-family:'Montserrat',sans-serif;
                font-weight:700;font-size:clamp(13px,1.4vw,15px);border-radius:999px;
                text-decoration:none;white-space:nowrap;transition:transform .15s ease}
    .watch-btn:hover{transform:scale(1.05)}.watch-btn:active{transform:scale(.97)}

    /* ── Progress bar (hidden until crown clicked) ── */
    #prog-wrap{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);
                width:min(340px,calc(100% - 60px));opacity:0;pointer-events:none;
                transition:opacity .55s ease}
    #prog-wrap.visible{opacity:1}
    #prog-rel{position:relative;width:100%}
    #prog-label{position:absolute;left:0%;bottom:calc(100% + 7px);
                 transform:translateX(-50%);font-family:'Montserrat',sans-serif;
                 font-weight:800;font-size:11px;color:#FFE800;letter-spacing:.5px;
                 white-space:nowrap;transition:left 2.5s ease-in-out}
    #prog-track{width:100%;height:10px;background:rgba(255,255,255,.18);
                 border-radius:999px;overflow:hidden}
    #prog-fill{width:0%;height:100%;background:#FFE800;border-radius:999px;
                box-shadow:0 0 10px rgba(255,232,0,.5);transition:width 2.5s ease-in-out}
  </style>
</head>
