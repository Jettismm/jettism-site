  <img id="crown" src="data:image/png;base64," alt="crown" draggable="false"/>

  <div id="content">
    <div id="coming-soon">coming soon &#x1F92B;</div>
    <a href="https://www.youtube.com/@Jettism" target="_blank" rel="noopener noreferrer" class="watch-btn">
      watch some videos while we wait
    </a>
  </div>

  <div id="prog-wrap">
    <div id="prog-rel">
      <div id="prog-label">0%</div>
      <div id="prog-track"><div id="prog-fill"></div></div>
    </div>
  </div>

  <script>
  (() => {
    /* ── Real bounce WAV ── */
    const _ba = new Audio('data:audio/wav;base64,'); _ba.load();
    function playBounce(n) {
      try {
        const a=_ba.cloneNode(); a.volume=Math.min(1,Math.max(.05,n));
        a.playbackRate=0.65+n*0.55; a.play().catch(()=>{});
      } catch(e){}
    }

    /* ── Synth sounds ── */
    const SYNTH = (() => {
      let ctx=null;
      const boot=()=>{ if(ctx) return; try{ctx=new(window.AudioContext||window.webkitAudioContext)();ctx.resume().catch(()=>{});}catch(e){} };
      const unlock=()=>{boot();ctx?.state==='suspended'&&ctx.resume().catch(()=>{});};
      boot(); ['mousedown','touchstart','pointerdown'].forEach(e=>document.addEventListener(e,unlock));
      const safe=fn=>{try{ctx?.state==='running'&&fn(ctx);}catch(e){}};
      return {
        click(){safe(c=>{
          const t=c.currentTime,o=c.createOscillator(),g=c.createGain();
          o.type='sine';o.frequency.setValueAtTime(580,t);o.frequency.exponentialRampToValueAtTime(82,t+.34);
          g.gain.setValueAtTime(.42,t);g.gain.exponentialRampToValueAtTime(.001,t+.37);
          o.connect(g);g.connect(c.destination);o.start(t);o.stop(t+.37);
          const o2=c.createOscillator(),g2=c.createGain();
          o2.type='square';o2.frequency.value=1400;
          g2.gain.setValueAtTime(.08,t);g2.gain.exponentialRampToValueAtTime(.001,t+.03);
          o2.connect(g2);g2.connect(c.destination);o2.start(t);o2.stop(t+.03);
        });},
        reveal(){safe(c=>{
          const t=c.currentTime;
          [520,740,980].forEach((f,i)=>{
            const o=c.createOscillator(),g=c.createGain();
            o.type='sine';o.frequency.value=f;
            g.gain.setValueAtTime(0,t+i*.1);g.gain.linearRampToValueAtTime(.14,t+i*.1+.04);
            g.gain.exponentialRampToValueAtTime(.001,t+i*.1+.55);
            o.connect(g);g.connect(c.destination);o.start(t+i*.1);o.stop(t+i*.1+.55);
          });
        });},
        progressFill(){safe(c=>{
          const t=c.currentTime,dur=2.35;
          const o=c.createOscillator(),g=c.createGain();
          o.type='sine';o.frequency.setValueAtTime(140,t);o.frequency.exponentialRampToValueAtTime(580,t+dur);
          g.gain.setValueAtTime(.04,t);g.gain.linearRampToValueAtTime(.12,t+dur*.6);
          g.gain.linearRampToValueAtTime(.13,t+dur*.88);g.gain.exponentialRampToValueAtTime(.001,t+dur+.1);
          o.connect(g);g.connect(c.destination);o.start(t);o.stop(t+dur+.1);
          const o2=c.createOscillator(),g2=c.createGain();
          o2.type='sine';o2.frequency.setValueAtTime(280,t);o2.frequency.exponentialRampToValueAtTime(1160,t+dur);
          g2.gain.setValueAtTime(.018,t);g2.gain.linearRampToValueAtTime(.055,t+dur*.75);
          g2.gain.exponentialRampToValueAtTime(.001,t+dur+.1);
          o2.connect(g2);g2.connect(c.destination);o2.start(t);o2.stop(t+dur+.1);
          [880,1320].forEach((f,i)=>{
            const td=t+dur+i*.13,o3=c.createOscillator(),g3=c.createGain();
            o3.type='sine';o3.frequency.value=f;
            g3.gain.setValueAtTime(0,td);g3.gain.linearRampToValueAtTime(.17,td+.05);
            g3.gain.exponentialRampToValueAtTime(.001,td+.75);
            o3.connect(g3);g3.connect(c.destination);o3.start(td);o3.stop(td+.75);
          });
        });},
      };
    })();

    /* ── DOM ── */
    const crownEl=document.getElementById('crown');
    const content=document.getElementById('content');
    const textEl=document.getElementById('coming-soon');
    const progWrap=document.getElementById('prog-wrap');
    const progFill=document.getElementById('prog-fill');
    const progLabel=document.getElementById('prog-label');
    const stripL=document.querySelector('.strip.L');
    const stripR=document.querySelector('.strip.R');

    /* ── Physics ── */
    const G_DROP=0.52,G_FREE=0.45,BOUNCE_D=0.64,WALL_D=0.68;
    const FRICTION=0.993,FLOOR_FR=0.82,FLOOR_PAD=82,MIN_SETTL=1.8,SND_THR=3;
    let px,py,vx=0,vy=0,crownW,crownH;
    let phase='waiting',isMoving=false,needsReveal=false,returnScheduled=false;
    let isDragging=false,hasMoved=false,dragOffX=0,dragOffY=0,posHistory=[];
    let squishRAF=null;

    const vw=()=>window.innerWidth,vh=()=>window.innerHeight;
    const floorY=()=>vh()-FLOOR_PAD-crownH;
    const centreX=()=>(vw()-crownW)/2;
    const centreY=()=>vh()*0.38-crownH/2;

    function onImpact(vel){
      const n=Math.min(1,vel/20);
      if(squishRAF) cancelAnimationFrame(squishRAF);
      crownEl.style.transition='transform 0s';
      crownEl.style.transform=`scaleX(${(1+n*.28).toFixed(3)}) scaleY(${(1-n*.26).toFixed(3)})`;
      squishRAF=requestAnimationFrame(()=>requestAnimationFrame(()=>{
        crownEl.style.transition='transform .32s cubic-bezier(.34,1.56,.64,1)';
        crownEl.style.transform='none';
      }));
      playBounce(n);
    }

    /* All reveals fire together when crown returns after first click */
    function revealAll(){
      content.style.top=(centreY()+crownH+30)+'px';
      content.classList.add('visible');
      textEl.classList.add('wiggling');
      SYNTH.reveal();

      /* Strips slide in slightly after content */
      setTimeout(()=>{stripL.classList.add('visible');stripR.classList.add('visible');},200);

      /* Progress bar */
      setTimeout(()=>progWrap.classList.add('visible'),280);
      setTimeout(()=>{
        progFill.style.width='7%';
        progLabel.style.left='7%';
        let t0=null;
        (function countUp(ts){
          if(!t0) t0=ts;
          const p=Math.min(1,(ts-t0)/2500);
          progLabel.textContent=Math.round(p*7)+'%';
          if(p<1) requestAnimationFrame(countUp);
          else progLabel.textContent='7%';
        })(performance.now());
        SYNTH.progressFill();
      },500);
    }

    /* ── RAF loop ── */
    function step(){
      requestAnimationFrame(step);
      if(phase==='waiting') return;
      if(isDragging) return;
      const floor=floorY(),maxX=vw()-crownW;

      if(phase==='first_bounce'){
        vy+=G_DROP;vx*=FRICTION;px+=vx;py+=vy;
        if(py>=floor){
          const imp=Math.abs(vy);py=floor;vy=-imp*BOUNCE_D;vx*=FLOOR_FR;
          if(imp>SND_THR) onImpact(imp);
          if(Math.abs(vy)<MIN_SETTL&&!returnScheduled){
            returnScheduled=true;vy=0;
            setTimeout(()=>{phase='first_return';},460);
          }
        }
        if(py<0){py=0;vy=Math.abs(vy)*WALL_D;}
        if(px<0){px=0;vx=Math.abs(vx)*WALL_D;}
        if(px>maxX){px=maxX;vx=-Math.abs(vx)*WALL_D;}

      } else if(phase==='first_return'){
        const cx=centreX(),cy=centreY(),dx=cx-px,dy=cy-py;
        vx=(vx+dx*.062)*.81;vy=(vy+dy*.062)*.81;px+=vx;py+=vy;
        if(Math.hypot(dx,dy)<.6&&Math.hypot(vx,vy)<.12){
          px=cx;py=cy;vx=vy=0;returnScheduled=false;
          phase='free';isMoving=false;
          crownEl.style.pointerEvents='auto';
          crownEl.classList.add('grab');
          if(needsReveal){needsReveal=false;revealAll();}
        }

      } else if(phase==='free'&&isMoving){
        vy+=G_FREE;vx*=FRICTION;px+=vx;py+=vy;
        if(py>=floor){
          const imp=Math.abs(vy);py=floor;vy=-imp*BOUNCE_D;vx*=FLOOR_FR;
          if(imp>SND_THR) onImpact(imp);
          if(Math.abs(vy)<.5) vy=0;
        }
        if(py<0){py=0;vy=Math.abs(vy)*WALL_D;}
        if(px<0){px=0;vx=Math.abs(vx)*WALL_D;}
        if(px>maxX){px=maxX;vx=-Math.abs(vx)*WALL_D;}
        if(Math.abs(vx)<.08&&Math.abs(vy)<.08){vx=vy=0;isMoving=false;}
      }

      if(phase!=='waiting'){crownEl.style.left=px+'px';crownEl.style.top=py+'px';}
    }

    /* ── Init ── */
    function init(){
      crownW=crownEl.offsetWidth;crownH=crownEl.offsetHeight;
      px=centreX();py=centreY();
      crownEl.style.left=px+'px';crownEl.style.top=py+'px';
      requestAnimationFrame(()=>{crownEl.style.opacity='1';});
      setTimeout(()=>{crownEl.style.pointerEvents='auto';crownEl.classList.add('idle');},650);
      requestAnimationFrame(step);
    }
    if(crownEl.complete&&crownEl.naturalHeight!==0) requestAnimationFrame(init);
    else crownEl.addEventListener('load',init,{once:true});

    /* ── Crown pointer events ── */
    crownEl.addEventListener('pointerdown',e=>{
      e.preventDefault();
      if(phase==='waiting'){
        needsReveal=true;phase='first_bounce';returnScheduled=false;
        crownEl.classList.remove('idle');crownEl.style.pointerEvents='none';
        vy=15;vx=(Math.random()-.5)*3.5;SYNTH.click();return;
      }
      if(phase!=='free') return;
      isDragging=true;hasMoved=false;
      dragOffX=e.clientX-px;dragOffY=e.clientY-py;
      posHistory=[{x:px,y:py,t:performance.now()}];
      crownEl.classList.replace('grab','grabbing');
      crownEl.style.transition='transform .1s ease';crownEl.style.transform='none';
      crownEl.setPointerCapture(e.pointerId);
    });

    crownEl.addEventListener('pointermove',e=>{
      if(!isDragging) return;
      const nx=e.clientX-dragOffX,ny=e.clientY-dragOffY;
      if(!hasMoved&&Math.hypot(nx-px,ny-py)>4) hasMoved=true;
      if(hasMoved){
        px=nx;py=ny;
        const now=performance.now();
        posHistory.push({x:px,y:py,t:now});
        posHistory=posHistory.filter(p=>now-p.t<100);
        crownEl.style.left=px+'px';crownEl.style.top=py+'px';
      }
    });

    crownEl.addEventListener('pointerup',()=>{
      if(!isDragging) return;
      isDragging=false;crownEl.classList.replace('grabbing','grab');isMoving=true;
      if(hasMoved){
        if(posHistory.length>=2){
          const a=posHistory[0],b=posHistory[posHistory.length-1];
          const dt=Math.max(1,b.t-a.t)/16.67;
          vx=(b.x-a.x)/dt;vy=(b.y-a.y)/dt;
          const spd=Math.hypot(vx,vy);if(spd>38){vx=vx/spd*38;vy=vy/spd*38;}
        }else{vx=vy=0;}
      }else{vy=12;vx=(Math.random()-.5)*3;SYNTH.click();}
    });

    window.addEventListener('resize',()=>{
      if(phase==='waiting'&&crownW){
        px=centreX();py=centreY();
        crownEl.style.left=px+'px';crownEl.style.top=py+'px';
      }
    });
  })();
  </script>
</body>
</html>
